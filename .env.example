# OpenAI API Key for agent brains
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Google API Key for alternative models
GOOGLE_API_KEY=your_google_api_key_here

# Optional: LangSmith for tracing agent execution
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=agentic-engineering-system

# --- API Server & Webhooks ---
# Secret configured in GitHub Webhook settings for HMAC validation
API_PORT=8000

# --- Ingestion & Smart Context Manager ---
# Path to Google Service Account JSON key (for Drive/Docs/Sheets)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
# Slack Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=
